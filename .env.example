# =============================================================================
# FINA - Environment Configuration
# =============================================================================
# Copy this file to .env and customize the values:
#
#   cp .env.example .env
#   nano .env
#
# Then run:
#   docker compose -f docker-compose.prod.yml up -d
#
# =============================================================================

# REQUIRED: Change this to a secure random string!
# Generate one with: openssl rand -hex 32
SECRET_KEY=change_this_to_a_random_string_at_least_32_characters

# Set to 'true' if running behind HTTPS reverse proxy (nginx, traefik, caddy)
HTTPS_ENABLED=false

# Session lifetime in seconds (default: 7 days = 604800)
SESSION_LIFETIME=604800
